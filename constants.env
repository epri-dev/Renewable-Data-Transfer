# © Electric Power Research Institute, Inc. (EPRI)
# ====================================================================
# This is the environment file for the reneawable data transfer. 
# It contains constants and configuration settings that are used throughout the data 
# processing pipeline.
# ====================================================================
SUPER = '1' # Set to 1 to enable SUPER data processing, 0 to disable
LEAP = '1' # Set to 1 to enable LEAP data processing, 0 to disable
BEST = '1' # Set to 1 to enable BEST data processing, 0 to disable

# SFTP and Data Generation Constants (Consistant across all transfers):
SFTP_USERNAME='abc_epri_001' # EPRI will provide the SFTP username
SFTP_PASSWORD='*****' # The password is set by the user after receiving the SFTP setup email from EPRI
SFTP_PRIVATE_KEY='XYZ.pem'  # This is the name of the SSH KEY. Replace the XYZ with the actual filename.
SFTP_PRIVATE_KEY_PASS='****'  # EPRI will provide the passphrase along with the SSH key
SFTP_HOST='transfer.data.epri.com'
USE_PASSWORD='1'  # Set to 1 to use password-based authentication
USE_SSHKEY='0'  # Set to 1 to use SSH key-based authentication
SLEEP_TIME=5  # Time to wait before retrying in case of failure
MAX_COUNT=3  # Maximum retry attempts

# SUPER specific details:
REMOTE_UPLOAD_FOLDER_SUPER='/Intake/DS0009XX-SUPER-XXXX' # EPRI will provide this directory. This is the remote directory where files will be pushed to thorugh SFTP
REMOTE_UPLOAD_FOLDER_TRACKERS='/Intake/DS XYZ/Trackers '# EPRI will provide this directory. This is the remote directory where tracker files will be pushed to through SFTP
CHANNEL_LIST_SUPER='ABC_channel_list_SUPER.xlsx' # Replace the XYZ with the filename of the channel list. No need to include the filepath here.
CHANNEL_LIST_VERSION_FLAG_SUPER='0' # write 0 if it is old version.
PERFORMANCE_ONLY='0'  # Set to 1 to process only performance data, No tracker data


# LEAP specific details:
REMOTE_UPLOAD_FOLDER_LEAP='/Intake/DS0009XX-LEAP-XXXX' # EPRI will provide this directory. This is the remote directory where files will be pushed to thorugh SFTP
CHANNEL_LIST_LEAP='ABC_channel_list_LEAP.xlsx' # Replace the XYZ with the filename of the channel list. No need to include the filepath here.

# BEST specific details:
REMOTE_UPLOAD_FOLDER_BEST='/Intake/DS0009XX-BEST-XXXX' # EPRI will provide this directory. This is the remote directory where files will be pushed to thorugh SFTP
CHANNEL_LIST_BEST='ABC_channel_list_BEST.xlsx' # Replace the XYZ with the filename of the channel list. No need to include the filepath here.
# ====================================================================
# ====================================================================
# ====================================================================
# No need to change below this line:
DATA_FILE_MAX_LENGTH_SUPER=1
RAW_DATA_INTERVAL_SUPER=5 # in minutes
DATA_FILE_MAX_LENGTH_TRACKERS=30
RAW_DATA_INTERVAL_TRACKERS=1

DATA_FILE_MAX_LENGTH_LEAP=1
RAW_DATA_INTERVAL_LEAP=10 # in minutes

DATA_FILE_MAX_LENGTH_BEST=1
RAW_DATA_INTERVAL_BEST=1 # in minutes