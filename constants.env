#Variables to update
SFTP_USERNAME='enter_username' # EPRI will provide the SFTP username
SFTP_PASSWORD='enter_password' # The password is set by the user after receiving the SFTP setup email from EPRI
SFTP_PRIVATE_KEY= 'XYZ.pem'  # This is the name of the SSH KEY. Replace the XYZ with the actual filename.
SFTP_PRIVATE_KEY_PASS='enter_passphrase'  # EPRI will provide the passphrase along with the SSH key
REMOTE_UPLOAD_FOLDER='/Intake/DS XYZ ' # EPRI will provide this directory. This is the remote directory where files will be pushed to thorugh SFTP
CHANNEL_LIST='channel_list.xlsx' # Replace the XYZ with the filename of the channel list. No need to include the filepath here.
CHANNEL_LIST_VERSION_FLAG='1' # write 0 if it is old version.
TRACKER_ONLY='0'  # Set to 1 to process only tracker data
PERFORMANCE_ONLY='1'  # Set to 1 to process only performance data

#Settings - no update is required to the variables below
SFTP_HOST='transfer.data.epri.com'
USE_PASSWORD='0'  # Set to 1 to use password-based authentication
USE_SSHKEY='1'  # Set to 1 to use SSH key-based authentication
SLEEP_TIME=30  # Time to wait before retrying in case of failure
MAX_COUNT=3  # Maximum retry attempts
DATA_FILE_MAX_LENGTH=1
RAW_DATA_INTERVAL=5

#Tracker Settings
DATA_FILE_MAX_LENGTH_TRACKERS=30
RAW_DATA_INTERVAL_TRACKERS=1
REMOTE_UPLOAD_FOLDER_TRACKERS='/Intake/DS XYZ/Trackers '# EPRI will provide this directory. This is the remote directory where tracker files will be pushed to through SFTP
